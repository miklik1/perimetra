/**
 * {{pascalCase singular}} schema — `pnpm gen module` scaffold of the reference resource
 * (spec §7.8; canonical copy: `packages/db/src/schema/projects`). Conventions
 * on display:
 *
 * - `id()` UUIDv7: time-ordered, so it doubles as the keyset-pagination
 *   cursor (no separate `created_at` cursor column needed).
 * - `organizationId` is THE access scope (ADR 0041 seam, activated ADR 0055):
 *   NOT NULL, every query in `{{kebabCase plural}}.repository.ts` filters on it via
 *   the RequestScope seam.
 * - `ownerId` is retained as the creator/audit ref (who made the row); it is
 *   no longer the access boundary.
 * - `softDelete()`: rows are never hard-deleted by the API; the partial
 *   index keeps the hot list query (live rows per org) tight.
 */
import { sql } from "drizzle-orm";
import { index, pgTable, text } from "drizzle-orm/pg-core";

import { id, softDelete, timestamps } from "../../columns.js";
import { organization, user } from "../auth/index.js";

export const {{constantCase singular}}_STATUSES = ["active", "archived"] as const;
export type {{pascalCase singular}}Status = (typeof {{constantCase singular}}_STATUSES)[number];

export const {{camelCase singular}} = pgTable(
  "{{snakeCase singular}}",
  {
    id: id(),
    /** Creator/audit ref (ADR 0055) — no longer the access scope. */
    ownerId: text("owner_id")
      .notNull()
      .references(() => user.id, { onDelete: "cascade" }),
    /** THE access scope (ADR 0041 seam, activated ADR 0055) — NOT NULL, filtered on. */
    organizationId: text("organization_id")
      .notNull()
      .references(() => organization.id, { onDelete: "cascade" }),
    // TODO(gen): replace this example column with the real domain fields.
    // Mirror every change in `@repo/validators/{{kebabCase plural}}` (the zod contract
    // owns the length bounds) and wrap personal-data columns with `pii()`
    // from `@repo/db/pii` (ADR 0040).
    name: text("name").notNull(),
    status: text("status").notNull().default("active").$type<{{pascalCase singular}}Status>(),
    ...timestamps(),
    ...softDelete(),
  },
  (table) => [
    // THE list query: WHERE organization_id = ? AND deleted_at IS NULL ORDER BY id.
    // Partial — soft-deleted rows leave the index instead of bloating it.
    index("{{snakeCase singular}}_org_id_id_idx")
      .on(table.organizationId, table.id)
      .where(sql`${table.deletedAt} IS NULL`),
  ],
);

export type {{pascalCase singular}}Row = typeof {{camelCase singular}}.$inferSelect;
export type New{{pascalCase singular}}Row = typeof {{camelCase singular}}.$inferInsert;
