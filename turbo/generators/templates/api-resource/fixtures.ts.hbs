import { type {{pascalCase resource}} } from "@repo/validators";

const TOTAL = 47;

/** Deterministic synthetic {{camelCase resource}} so the demo has rows to page. */
function build{{pascalCase resource}}(i: number): {{pascalCase resource}} {
  const seq = String(i).padStart(12, "0");
  return {
    id: `00000000-0000-4000-8000-${seq}`,
{{#each fields}}
    {{this.name}}: {{{this.mock}}},
{{/each}}
    createdAt: "2026-01-01T00:00:00.000Z",
  };
}

const {{camelCase resource}}Fixtures: {{pascalCase resource}}[] = Array.from({ length: TOTAL }, (_, idx) =>
  build{{pascalCase resource}}(idx + 1),
);

export function list{{pascalCase resource}}s(): {{pascalCase resource}}[] {
  return {{camelCase resource}}Fixtures;
}

export function find{{pascalCase resource}}ById(id: string): {{pascalCase resource}} | undefined {
  return {{camelCase resource}}Fixtures.find((item) => item.id === id);
}

export function page{{pascalCase resource}}s(
  page: number,
  perPage: number,
): { data: {{pascalCase resource}}[]; nextPage: number | null } {
  const start = (page - 1) * perPage;
  const data = {{camelCase resource}}Fixtures.slice(start, start + perPage);
  const nextPage = start + perPage < TOTAL ? page + 1 : null;
  return { data, nextPage };
}
