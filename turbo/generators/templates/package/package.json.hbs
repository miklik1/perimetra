{
  "name": "@repo/{{kebabCase name}}",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
{{#if internalDeps.length}}
  "dependencies": {
{{#each internalDeps}}
    "@repo/{{this}}": "workspace:*"{{#unless @last}},{{/unless}}
{{/each}}
  },
{{/if}}
{{#if needsReact}}
  "peerDependencies": {
    "react": "*"
  },
{{/if}}
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
{{#if needsReact}}
    "@types/react": "catalog:react19",
{{else}}
    "@types/node": "catalog:",
{{/if}}
    "eslint": "catalog:",
{{#if needsReact}}
    "react": "catalog:react19",
{{/if}}
    "typescript": "catalog:"
  }
}
