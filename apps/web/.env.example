# Validated by @repo/config/env/web (zod via @t3-oss/env-nextjs).
# Copy to .env.local and fill. NEXT_PUBLIC_* vars are exposed to the browser.
# Every var below is OPTIONAL — the skeleton boots with none set (demo runs on
# the bundled mocks). Empty strings are treated as unset.

# --- API / BFF + auth proxy (ADR 0018; Better Auth design §7.1/§9) ---
# The real backend (API service) origin. Server-only (NOT NEXT_PUBLIC_) so it
# never reaches the browser — requests stay same-origin under /api. Two uses:
#  - next.config.js rewrites /api/auth/* (Better Auth) and /api/v1/* straight
#    here when mocks are off, so the httpOnly session cookie stays first-party
#    (default for the rewrites when unset: http://localhost:4000).
#  - everything else goes through the BFF route handler, which proxies here
#    (defaults to https://jsonplaceholder.typicode.com when unset; credentials
#    are only forwarded once API_URL is explicitly set).
# Must be a valid URL.
# API_URL=http://localhost:4000

# --- Dev mocks (MSW, ADR 0016/0018) ---
# Dev-only API mocking via the BFF route handler, served server-side from
# @repo/api-mocks. Tri-state: "true" forces mocks on, "false" forces them off,
# and UNSET defaults to mocks ON while no API_URL is configured (a fresh clone
# runs self-contained) and OFF once API_URL is set. MSW_MOCKS selects which
# groups are mocked (comma-separated; unset = all); unlisted groups fall
# through to the real backend (partial mocking).
# NEXT_PUBLIC_ENABLE_MSW=true
# NEXT_PUBLIC_MSW_MOCKS=auth,users,projects

# --- Realtime / Centrifugo (ADR 0029; design §7.3) ---
# Centrifugo websocket endpoint for the LIVE badge on /projects. NEXT_PUBLIC_
# (inlined into the client bundle). Unset ⇒ the local-stack default below.
# Tokens are minted by the API (GET /v1/realtime/token, POST
# /v1/realtime/subscribe-token) through the same-origin proxy.
# NEXT_PUBLIC_REALTIME_URL=ws://localhost:8000/connection/websocket

# --- Debug (ADR 0018 observability) ---
# Dev-only: log every API request/response + timing via the injectable debug
# middleware. Tree-shaken out unless set. "true" | "false".
# NEXT_PUBLIC_DEBUG_API=true

# --- Sentry error tracking (ADR 0021) ---
# All optional: no DSN ⇒ telemetry stays the silent no-op (the dev/test default).
# NEXT_PUBLIC_* (not server twins) because instrumentation-client.ts only sees
# inlined client vars and the server init reads the same values.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
#
# SENTRY_AUTH_TOKEN: source-map upload, build/CI only (consumed by withSentryConfig).
# Server-only. Absent ⇒ upload silently skipped; `next build` never depends on it.
# SENTRY_AUTH_TOKEN=

# --- PostHog feature flags + product analytics (ADR 0028) ---
# All optional: no key ⇒ flags serve registry defaults and analytics stays the
# silent no-op (the dev/test default). NEXT_PUBLIC_* for the same reason as Sentry:
# the client init reads them and the server flag eval reads the same values.
# Host defaults to EU cloud (https://eu.i.posthog.com) at the use-site when unset.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
#
# POSTHOG_PERSONAL_API_KEY: server-only, optional tuning. Present ⇒ posthog-node
# evaluates flags in-process (no per-request call to PostHog); absent ⇒ one remote
# /flags call per request. Never client-visible.
# POSTHOG_PERSONAL_API_KEY=
