# Validated by @repo/config/env/mobile (zod via @t3-oss/env-core).
# Copy to .env.local and fill. EXPO_PUBLIC_* vars are inlined into the JS bundle.

# Optional. Defaults to https://jsonplaceholder.typicode.com when unset
# (resolved in apps/mobile/app/_layout.tsx). Must be a valid URL.
# EXPO_PUBLIC_API_URL=https://api.example.com

# Sentry error tracking (ADR 0021). DECLARED but the native adapter is deferred
# (dormant mobile app — see lib/telemetry-boot.ts). When wired: no DSN ⇒ the
# silent no-op; with a DSN the capture seam goes live. Sample rate is 0..1.
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog feature flags + product analytics (ADR 0028). DECLARED but the native
# adapter is deferred. When wired: no key ⇒ registry-default flags + no-op
# analytics; with a key the flags/analytics seams go live. Host defaults to
# PostHog cloud when unset.
# EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
