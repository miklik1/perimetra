# apps/api environment — copy to .env.local for local overrides.
# Every variable is parsed fail-fast by src/common/config/env.ts; the dev
# defaults below match docker/compose.yaml, so an empty file works for dev.

# --- Core ---
# NODE_ENV=development
# PORT=4000
# HOST=0.0.0.0
# LOG_LEVEL=info
# Set true behind the Next.js proxy / a load balancer (real client IPs).
# TRUST_PROXY=false
# BODY_LIMIT_BYTES=1048576

# --- Database ---
# DATABASE_URL=postgres://app:app@localhost:5432/app
# DATABASE_POOL_SIZE=10

# --- Redis (Better Auth secondary storage; Phase 4 queues/cache) ---
# REDIS_URL=redis://localhost:6379

# --- Better Auth (ADR 0033) ---
# Signing/encryption secret. The dev placeholder is NOT safe for prod —
# generate one: openssl rand -base64 32
# BETTER_AUTH_SECRET=dev-secret-change-me
# Public base URL of this api (callback/redirect URLs derive from it).
# BETTER_AUTH_URL=http://localhost:4000
# Web app origin — Better Auth trusted origin for its origin/CSRF check.
# WEB_ORIGIN=http://localhost:3000

# ---- jobs / outbox (ADR 0037/0043) ------------------------------------
# OUTBOX_RELAY_INTERVAL_MS=500
# BULL_BOARD_USER=admin
# BULL_BOARD_PASSWORD=admin

# ---- email (Mailpit dev defaults; spec 7.4) ----------------------------
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM="Skeleton <no-reply@localhost>"

# ---- storage (MinIO dev defaults; spec 7.5) ----------------------------
# S3_ENDPOINT must be browser-reachable: presigned URLs embed it.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio-dev-password
# S3_BUCKET=app

# ---- realtime (Centrifugo dev defaults; spec 7.3) ----------------------
# CENTRIFUGO_URL=http://localhost:8000
# CENTRIFUGO_API_KEY=dev-centrifugo-api-key
# CENTRIFUGO_TOKEN_SECRET=dev-centrifugo-token-secret

# ---- throttling (ADR 0044) ---------------------------------------------
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=100
# AUTH_RATE_LIMIT_MAX=10

# ---- observability & analytics (ADR 0036) — all OPT-IN -----------------
# OTel: set an exporter to enable (standard SDK vars; see OBSERVABILITY.md)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACES_EXPORTER=console
# OTEL_METRICS_EXPORTER=console
# Sentry (errors only — traces belong to OTel)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# PostHog server-side (EU cloud default; personal key enables local flag
# evaluation AND the GDPR person-deletion purge hook)
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=
