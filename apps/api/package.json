{
  "name": "api",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "concurrently -k -n tsc,node \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"node --watch --enable-source-maps --import ./dist/otel/loader.js --env-file-if-exists=.env.local dist/main.js\"",
    "start": "node --enable-source-maps --import ./dist/otel/loader.js --env-file-if-exists=.env.local dist/main.js",
    "start:worker": "node --enable-source-maps --import ./dist/otel/loader.js --env-file-if-exists=.env.local dist/worker.js",
    "migrate": "node --enable-source-maps --import ./dist/otel/loader.js --env-file-if-exists=.env.local dist/migrate.js",
    "seed": "node --enable-source-maps --env-file-if-exists=.env.local dist/seed.js",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1065.0",
    "@aws-sdk/s3-request-presigner": "3.1065.0",
    "@bull-board/api": "^7.2.1",
    "@bull-board/fastify": "^7.2.1",
    "@fastify/basic-auth": "6.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/otel": "catalog:",
    "@fastify/rate-limit": "^11.0.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs-cls/transactional": "^3.2.1",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "^1.2.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-fastify": "^11.1.26",
    "@nestjs/swagger": "catalog:",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-http": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/instrumentation": "catalog:",
    "@opentelemetry/instrumentation-ioredis": "catalog:",
    "@opentelemetry/instrumentation-pg": "catalog:",
    "@opentelemetry/instrumentation-pino": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@repo/db": "workspace:*",
    "@repo/engine": "workspace:*",
    "@repo/fixtures": "workspace:*",
    "@repo/flags": "workspace:*",
    "@repo/i18n": "workspace:*",
    "@repo/model": "workspace:*",
    "@repo/renderers": "workspace:*",
    "@repo/validators": "workspace:*",
    "@sentry/node": "catalog:",
    "better-auth": "catalog:",
    "bullmq": "^5.78.0",
    "bullmq-otel": "^1.3.1",
    "drizzle-orm": "1.0.0-rc.3",
    "fastify": "catalog:",
    "ioredis": "catalog:",
    "jose": "6.2.3",
    "nestjs-cls": "^6.2.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "catalog:",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "posthog-node": "catalog:",
    "react": "catalog:react19",
