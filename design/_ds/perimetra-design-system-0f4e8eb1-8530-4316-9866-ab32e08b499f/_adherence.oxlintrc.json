{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/forms/ArrayField/**",
              "components/forms/DisclosureSection/**",
              "components/forms/EnumSelect/**",
              "components/forms/FieldShell/**",
              "components/general/Badge/**",
              "components/general/Button/**",
              "components/general/Checkbox/**",
              "components/general/DefectList/**",
              "components/general/Dialog/**",
              "components/general/DisplayLabel/**",
              "components/general/EmptyState/**",
              "components/general/Field/**",
              "components/general/FieldError/**",
              "components/general/IconButton/**",
              "components/general/IconCluster/**",
              "components/general/Input/**",
              "components/general/NavTree/**",
              "components/general/Pager/**",
              "components/general/Panel/**",
              "components/general/Popover/**",
              "components/general/SegmentedNav/**",
              "components/general/SegmentedNavItem/**",
              "components/general/Select/**",
              "components/general/Separator/**",
              "components/general/Sheet/**",
              "components/general/Skeleton/**",
              "components/general/Spinner/**",
              "components/general/StatCard/**",
              "components/general/StepNav/**",
              "components/general/Switch/**",
              "components/general/Tabs/**",
              "components/general/Textarea/**",
              "components/general/Toast/**",
              "components/general/ToastViewport/**",
              "components/general/Tooltip/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Chillax|Synonym|Amulya|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Chillax, Synonym, Amulya, Geist Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
