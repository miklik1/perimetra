{
  "name": "@repo/validators",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./orders": {
      "types": "./dist/orders.d.ts",
      "default": "./dist/orders.js"
    },
    "./legal-profiles": {
      "types": "./dist/legal-profiles.d.ts",
      "default": "./dist/legal-profiles.js"
    },
    "./customers": {
      "types": "./dist/customers.d.ts",
      "default": "./dist/customers.js"
    },
    "./lookups": {
      "types": "./dist/lookups.d.ts",
      "default": "./dist/lookups.js"
    },
    "./release-drafts": {
      "types": "./dist/release-drafts.d.ts",
      "default": "./dist/release-drafts.js"
    },
    "./quotes": {
      "types": "./dist/quotes.d.ts",
      "default": "./dist/quotes.js"
    },
    "./price-tables": {
      "types": "./dist/price-tables.d.ts",
      "default": "./dist/price-tables.js"
    },
    "./catalog-versions": {
      "types": "./dist/catalog-versions.d.ts",
      "default": "./dist/catalog-versions.js"
    },
    "./releases": {
      "types": "./dist/releases.d.ts",
      "default": "./dist/releases.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    },
    "./projects": {
      "types": "./dist/projects.d.ts",
      "default": "./dist/projects.js"
    },
    "./project-site": {
      "types": "./dist/project-site.d.ts",
      "default": "./dist/project-site.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "eslint": "catalog:",
    "tsc-alias": "^1.8.16",
    "typescript": "catalog:"
  }
}
