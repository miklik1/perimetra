{
  "name": "@repo/validators",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./catalog-versions": {
      "types": "./dist/catalog-versions.d.ts",
      "default": "./dist/catalog-versions.js"
    },
    "./releases": {
      "types": "./dist/releases.d.ts",
      "default": "./dist/releases.js"
    },
    "./projects": {
      "types": "./dist/projects.d.ts",
      "default": "./dist/projects.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "eslint": "catalog:",
    "tsc-alias": "^1.8.16",
    "typescript": "catalog:"
  }
}
