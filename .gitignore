# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing (turbo `test` output per-package/app, ADR 0025 — anchored to one path
# segment under apps/*|packages/* so it can never shadow a nested source dir of
# the same name; Engineering finding 2026-06-12)
apps/*/coverage/
packages/*/coverage/
tooling/*/coverage/

# Playwright (web E2E — ADR 0025) — anchored to where apps/web actually writes it
# (apps/web/playwright.config.ts has no outputDir override, so Playwright's
# default applies relative to that config file)
apps/web/test-results/
apps/web/playwright-report/
apps/web/playwright/.cache/

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs (per-package/app dist, anchored — never shadow a `dist`/`build`
# source dir of the same name; Engineering finding 2026-06-12)
.next/
out/
apps/*/dist/
packages/*/dist/


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Expo
.expo/
android/
ios/
*.jks
*.keystore

# IDE
# .vscode/ is committed (shared settings.json + extensions.json); ignore only
# per-user overrides and machine-local files.
.vscode/*.local.json
.vscode/settings.local.json
.idea/

# Misc
.DS_Store
*.pem
# Claude Code: ignore local/personal settings, but COMMIT the shared project
# config (it carries the Stop-hook quality gate — scripts/claude-gate.sh).
.claude/*
!.claude/settings.json

# machine-local compose overrides
docker/.env
