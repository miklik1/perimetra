# docker compose host-config — copy to docker/.env for local overrides.
#
# OPTIONAL. With no docker/.env, `pnpm run setup` runs the whole stack on the
# compose defaults (pg 5432, redis 6379, centrifugo 8000, minio 9000/9001,
# mailpit 1025/8025, pgbouncer 6432) and the app dev defaults in env.ts already
# match — so a fresh single-repo checkout needs NOTHING here.
#
# You only need docker/.env to run MULTIPLE skeleton-stamped repos on ONE
# machine at once: every stamped repo's compose hardcodes `name:
# fullstack-skeleton`, so without overrides they'd share container names AND
# collide on host ports. To coexist, give THIS repo:
#   1. a distinct COMPOSE_PROJECT_NAME (outranks the hardcoded compose name), and
#   2. a UNIFORM host-port offset applied to EVERY port below (preserve the gaps).
# Pick a distinct offset per repo — convention in the vault finding "Compose
# project-name collision in stamped repos": e.g. anyora +0 (bare defaults),
# mercata +1 (5433/6380/…), perimetra +2 (5434/6381/…).
#
# IMPORTANT: if you offset these ports, mirror them in the gitignored
# apps/api/.env.local (DATABASE_URL, REDIS_URL, CENTRIFUGO_URL, S3_ENDPOINT,
# SMTP_PORT, PORT, BETTER_AUTH_URL, WEB_ORIGIN) and apps/web/.env.local
# (API_URL, NEXT_PUBLIC_REALTIME_URL) — see those .env.example files. CI and
# fresh clones stay on the defaults; never edit the env.ts defaults.

# Container namespace — set to this repo's name to keep containers separate.
COMPOSE_PROJECT_NAME=perimetra

# Host ports — compose defaults shown; uncomment + offset uniformly to coexist.
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# CENTRIFUGO_HOST_PORT=8000
# MINIO_API_HOST_PORT=9000
# MINIO_CONSOLE_HOST_PORT=9001
# MAILPIT_SMTP_HOST_PORT=1025
# MAILPIT_WEB_HOST_PORT=8025
# PGBOUNCER_HOST_PORT=6432
